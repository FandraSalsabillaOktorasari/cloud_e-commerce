# ────────────────────────────────────────────────────────────────
# TechStore — Environment Configuration
# ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your setup.
# Run: cp .env.example .env && php artisan key:generate

APP_NAME=TechStore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ────────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ────────────────────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────────────────────
# Supported: sqlite, mysql, pgsql, sqlsrv
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=techstore
DB_USERNAME=root
DB_PASSWORD=

# ────────────────────────────────────────────────────────────────
# Session & Cache
# ────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
# CACHE_PREFIX=

# ────────────────────────────────────────────────────────────────
# Queue & Broadcasting
# ────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database

# ────────────────────────────────────────────────────────────────
# Filesystem (Storage)
# ────────────────────────────────────────────────────────────────
# Default: "local" (stores files in storage/app)
# For cloud: set to "s3" and fill in AWS credentials below
FILESYSTEM_DISK=public

# ────────────────────────────────────────────────────────────────
# AWS S3 (for cloud file storage / deployment)
# ────────────────────────────────────────────────────────────────
# Used when FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=techstore-uploads
AWS_USE_PATH_STYLE_ENDPOINT=false

# ────────────────────────────────────────────────────────────────
# Redis (optional)
# ────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MEMCACHED_HOST=127.0.0.1

# ────────────────────────────────────────────────────────────────
# Mail
# ────────────────────────────────────────────────────────────────
# Supported: smtp, mailgun, ses, log, array
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="support@techstore.id"
MAIL_FROM_NAME="${APP_NAME}"

# ────────────────────────────────────────────────────────────────
# Vite
# ────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
